---
---

<div id="store-modal" class="modal-overlay" aria-modal="true" role="dialog" aria-hidden="true">
  <div class="modal-card">
    <button class="modal-close" aria-label="Fechar">&#x2715;</button>
    <div class="modal-banner" id="modal-banner">
      <img id="modal-banner-img" src="" alt="" loading="lazy" />
    </div>
    <div class="modal-body">
      <div class="modal-tags" id="modal-tags"></div>
      <p class="modal-description" id="modal-description"></p>
    </div>
    <div class="modal-footer">
      <a id="modal-link" class="modal-cta" href="#" target="_blank" rel="noopener noreferrer">
        Ir para a loja →
      </a>
      <span id="modal-construction" class="modal-construction">🚧 Em Construção</span>
    </div>
  </div>
</div>

<style>
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.72);
    backdrop-filter: blur(6px);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }

  .modal-overlay.open {
    opacity: 1;
    pointer-events: all;
  }

  .modal-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    max-width: 540px;
    width: 100%;
    max-height: 88vh;
    overflow-y: auto;
    position: relative;
    transform: translateY(24px) scale(0.98);
    transition: transform 0.25s ease;
  }

  .modal-overlay.open .modal-card {
    transform: translateY(0) scale(1);
  }

  .modal-close {
    position: absolute;
    top: 0.85rem;
    right: 0.85rem;
    background: rgba(0, 0, 0, 0.45);
    border: none;
    color: #fff;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    font-size: 0.9rem;
    cursor: pointer;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }

  .modal-close:hover {
    background: rgba(0, 0, 0, 0.7);
  }

  .modal-banner {
    width: 100%;
    height: 200px;
    position: relative;
    overflow: hidden;
  }

  #modal-banner-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .modal-body {
    padding: 1.5rem 1.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .modal-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .modal-tag {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 0.28rem 0.75rem;
    border-radius: 999px;
    border: 1px solid var(--accent-cyan);
    color: var(--accent-cyan);
    background: rgba(0, 212, 255, 0.06);
    letter-spacing: 0.03em;
  }

  .modal-tag.construction {
    border-color: var(--accent-purple);
    color: var(--accent-purple);
    background: rgba(138, 43, 226, 0.06);
  }

  .modal-description {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 0;
  }

  .modal-footer {
    padding: 1.25rem 1.5rem 1.5rem;
  }

  .modal-cta {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 600;
    color: #0a0a14;
    background: linear-gradient(135deg, var(--accent-cyan), var(--accent-purple));
    padding: 0.7rem 1.6rem;
    border-radius: 8px;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.2s;
  }

  .modal-cta:hover {
    opacity: 0.88;
    transform: translateY(-1px);
  }

  .modal-construction {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-muted);
    border: 1px solid var(--border);
    padding: 0.7rem 1.6rem;
    border-radius: 8px;
  }
</style>

<script>
  import { stores } from '../data/stores';

  const overlay = document.getElementById('store-modal')!;
  const bannerEl = document.getElementById('modal-banner') as HTMLElement;
  const bannerImg = document.getElementById('modal-banner-img') as HTMLImageElement;
  const tagsEl = document.getElementById('modal-tags')!;
  const descEl = document.getElementById('modal-description')!;
  const linkEl = document.getElementById('modal-link') as HTMLAnchorElement;
  const constructionEl = document.getElementById('modal-construction')!;
  const closeBtn = overlay.querySelector('.modal-close')!;

  function openModal(storeKey: string) {
    const store = stores[storeKey];
    if (!store) return;

    bannerEl.style.background = store.bannerGradient;

    if (store.banner) {
      bannerImg.src = store.banner;
      bannerImg.alt = store.name;
      bannerImg.style.display = 'block';
      bannerImg.onerror = () => { bannerImg.style.display = 'none'; };
    } else {
      bannerImg.style.display = 'none';
    }

    const isConstruction = store.status === 'construction';
    tagsEl.innerHTML = store.tags
      .map(tag => `<span class="modal-tag${isConstruction ? ' construction' : ''}">${tag}</span>`)
      .join('');

    descEl.textContent = store.description;

    if (store.url) {
      linkEl.href = store.url;
      linkEl.style.display = 'inline-block';
      constructionEl.style.display = 'none';
    } else {
      linkEl.style.display = 'none';
      constructionEl.style.display = 'inline-block';
    }

    overlay.setAttribute('aria-hidden', 'false');
    overlay.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    overlay.classList.remove('open');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  document.addEventListener('click', (e) => {
    const trigger = (e.target as Element).closest('[data-store]');
    if (trigger) {
      const key = trigger.getAttribute('data-store')!;
      openModal(key);
    }
  });

  closeBtn.addEventListener('click', closeModal);

  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) closeModal();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
</script>
