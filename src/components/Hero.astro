---
// src/components/Hero.astro
---

<section id="hero">
  <div class="hero-pattern"></div>
  <div class="hero-content fade-in">
    <h1 class="hero-name">Raphael<br/>Romão</h1>
    <p class="hero-title" data-i18n="hero.title">Dev Full-Stack · Shopify · IA</p>
    <p class="hero-tagline" data-i18n="hero.tagline">
      Construo experiências digitais — de lojas Shopify a aplicações com inteligência artificial.
    </p>
    <div class="hero-badges">
      <span class="badge">Next.js</span>
      <span class="badge">Shopify</span>
      <span class="badge">Claude API</span>
      <span class="badge">Python</span>
      <span class="badge">Astro</span>
    </div>
  </div>
</section>

<style>
  #hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    padding: 8rem 1.5rem 4rem;
  }

  .hero-pattern {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(0,212,255,0.06) 1px, transparent 1px);
    background-size: 32px 32px;
    pointer-events: none;
  }

  .hero-content {
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
    position: relative;
    z-index: 1;
  }

  .hero-name {
    font-size: clamp(3.5rem, 10vw, 7rem);
    font-weight: 700;
    line-height: 1;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, var(--accent-cyan) 0%, #ffffff 50%, var(--accent-purple) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-title {
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--accent-cyan);
    margin-bottom: 1.5rem;
    letter-spacing: 0.05em;
  }

  .hero-tagline {
    font-size: 1.15rem;
    color: var(--text-muted);
    max-width: 540px;
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
</style>
