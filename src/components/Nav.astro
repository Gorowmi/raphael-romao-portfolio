---
// src/components/Nav.astro
---

<nav id="nav">
  <div class="nav-inner">
    <a class="nav-logo" href="#hero">RR</a>
    <ul class="nav-links">
      <li><a href="#about" data-i18n="nav.about">Sobre</a></li>
      <li><a href="#projects" data-i18n="nav.projects">Projetos</a></li>
      <li><a href="#stack" data-i18n="nav.stack">Stack</a></li>
      <li><a href="#contact" data-i18n="nav.contact">Contato</a></li>
    </ul>
    <button id="lang-toggle" aria-label="Toggle language">PT | EN</button>
    <button id="nav-hamburger" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
  <ul class="nav-mobile" id="nav-mobile">
    <li><a href="#about" data-i18n="nav.about">Sobre</a></li>
    <li><a href="#projects" data-i18n="nav.projects">Projetos</a></li>
    <li><a href="#stack" data-i18n="nav.stack">Stack</a></li>
    <li><a href="#contact" data-i18n="nav.contact">Contato</a></li>
  </ul>
</nav>

<style>
  #nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(7, 8, 15, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-logo {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    background: linear-gradient(90deg, var(--accent-cyan), var(--accent-purple));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 2rem;
    margin-left: auto;
  }

  .nav-links a {
    color: var(--text-muted);
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: var(--text);
    text-decoration: none;
  }

  #lang-toggle {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent-cyan);
    background: transparent;
    border: 1px solid var(--border);
    padding: 0.3rem 0.7rem;
    border-radius: 4px;
    cursor: pointer;
    transition: background 0.2s;
  }

  #lang-toggle:hover {
    background: rgba(0, 212, 255, 0.1);
  }

  #nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
  }

  #nav-hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: all 0.3s;
  }

  .nav-mobile {
    display: none;
    list-style: none;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid var(--border);
  }

  .nav-mobile.open {
    display: flex;
  }

  .nav-mobile a {
    display: block;
    padding: 1rem 1.5rem;
    color: var(--text-muted);
    font-size: 1rem;
  }

  .nav-mobile a:hover {
    color: var(--text);
    text-decoration: none;
    background: rgba(255,255,255,0.03);
  }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    #nav-hamburger { display: flex; margin-left: auto; }
  }
</style>

<script>
  import ptJson from '../i18n/pt.json';
  import enJson from '../i18n/en.json';

  const translations: Record<string, Record<string, string>> = { pt: ptJson, en: enJson };
  let currentLang: 'pt' | 'en' = (localStorage.getItem('lang') as 'pt' | 'en') || 'pt';

  function applyLang(lang: 'pt' | 'en') {
    currentLang = lang;
    localStorage.setItem('lang', lang);
    document.documentElement.lang = lang === 'pt' ? 'pt-BR' : 'en';
    document.querySelectorAll('[data-i18n]').forEach((el) => {
      const key = el.getAttribute('data-i18n')!;
      if (translations[lang][key]) el.textContent = translations[lang][key];
    });
    const toggle = document.getElementById('lang-toggle');
    if (toggle) toggle.textContent = lang === 'pt' ? 'PT | EN' : 'EN | PT';
    window.dispatchEvent(new CustomEvent('langchange', { detail: lang }));
  }

  document.getElementById('lang-toggle')?.addEventListener('click', () => {
    applyLang(currentLang === 'pt' ? 'en' : 'pt');
  });

  const hamburger = document.getElementById('nav-hamburger');
  const mobileMenu = document.getElementById('nav-mobile');
  hamburger?.addEventListener('click', () => {
    const open = mobileMenu?.classList.toggle('open');
    hamburger.setAttribute('aria-expanded', String(open));
  });

  document.querySelectorAll('.nav-mobile a').forEach(link => {
    link.addEventListener('click', () => mobileMenu?.classList.remove('open'));
  });

  applyLang(currentLang);
</script>
