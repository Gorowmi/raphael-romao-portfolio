---
// src/components/Contact.astro
---

<section id="contact">
  <div class="section fade-in">
    <h2 class="section-title" data-i18n="contact.title">Contato</h2>
    <p class="contact-cta" data-i18n="contact.cta">
      Tem um projeto em mente? Me chama.
    </p>
    <div class="contact-links">
      <a href="mailto:raphael.romao1998@gmail.com" class="contact-link">
        <span class="contact-icon">✉</span>
        <span>
          <span class="contact-label" data-i18n="contact.email">E-mail</span>
          <span class="contact-value">raphael.romao1998@gmail.com</span>
        </span>
      </a>
      <a href="https://www.linkedin.com/in/raphael-romao/" target="_blank" rel="noopener" class="contact-link">
        <span class="contact-icon">in</span>
        <span>
          <span class="contact-label" data-i18n="contact.linkedin">LinkedIn</span>
          <span class="contact-value">linkedin.com/in/raphael-romao</span>
        </span>
      </a>
    </div>
  </div>
</section>

<style>
  .contact-cta {
    font-size: 1.25rem;
    color: var(--text-muted);
    margin-bottom: 2.5rem;
    max-width: 400px;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 440px;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.2rem 1.5rem;
    transition: border-color 0.2s, box-shadow 0.2s;
    text-decoration: none;
    color: inherit;
  }

  .contact-link:hover {
    border-color: var(--accent-cyan);
    box-shadow: 0 0 16px rgba(0, 212, 255, 0.06);
    text-decoration: none;
  }

  .contact-icon {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    background: rgba(0, 212, 255, 0.08);
    color: var(--accent-cyan);
    flex-shrink: 0;
  }

  .contact-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
  }

  .contact-value {
    display: block;
    font-size: 0.95rem;
    color: var(--text);
    margin-top: 0.1rem;
  }
</style>
