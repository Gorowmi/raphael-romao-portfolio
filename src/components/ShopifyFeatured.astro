---
import ProjectCard from './ProjectCard.astro';
---

<div class="featured-section">
  <h3 class="sub-title" data-i18n="projects.shopify.featured.label">Shopify — Trabalhos em Destaque</h3>
  <p class="shopify-role" data-i18n="projects.shopify.role">Lojas em que atuei como desenvolvedor Shopify — customizações de tema, features e integrações.</p>
  <div class="cards-grid">
    <div class="store-trigger" data-store="simboliq">
      <ProjectCard
        name="Simboliq"
        descKey="projects.simboliq.description"
        stack={['Shopify', 'Liquid', 'Prestige Theme', 'CSS']}
      />
    </div>
    <div class="store-trigger" data-store="joyaclean">
      <ProjectCard
        name="JoyaClean"
        descKey="projects.joyaclean.description"
        stack={['Shopify', 'Liquid', 'Glaze Theme', 'Metafields', 'CSS']}
      />
    </div>
    <div class="store-trigger" data-store="testyou">
      <ProjectCard
        name="Testyou"
        descKey="projects.testyou.description"
        stack={['Shopify', 'Liquid', 'JavaScript', 'Symmetry Theme']}
      />
    </div>
  </div>
</div>

<style>
  .featured-section {
    margin-bottom: 4rem;
  }

  .shopify-role {
    font-size: 0.95rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    max-width: 560px;
  }

  .sub-title {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .store-trigger {
    cursor: pointer;
  }

  .store-trigger:hover :global(.project-card) {
    border-color: var(--accent-cyan);
    box-shadow: 0 0 24px rgba(0, 212, 255, 0.08);
  }
</style>
