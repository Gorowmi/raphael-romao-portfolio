---
// src/components/Projects.astro
import ProjectCard from './ProjectCard.astro';
import ShopifyFeatured from './ShopifyFeatured.astro';
import ShopifyGrid from './ShopifyGrid.astro';
---

<section id="projects">
  <div class="section">
    <h2 class="section-title" data-i18n="projects.title">Projetos</h2>

    <h3 class="sub-title" data-i18n="projects.tech.label">Projetos Tech</h3>
    <div class="cards-grid">
      <ProjectCard
        name="Escritório Virtual"
        descKey="projects.escritorio.description"
        stack={['Next.js', 'PixiJS', 'Socket.io', 'Supabase', 'Claude API']}
      />
    </div>

    <ShopifyFeatured />
    <ShopifyGrid />
  </div>
</section>

<style>
  .sub-title {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
    margin-bottom: 4rem;
  }
</style>
